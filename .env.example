# SyncCore environment configuration
# Copy this file to .env and set your values.

# Folders
SYNC_FOLDER=./data/sync_folder

# Networking
SERVER_URL=https://localhost:8443
PORT=8443

# Security
API_KEY=change-me-to-a-real-secret
SSL_CERT=cert.pem
SSL_KEY=key.pem

# Identity — must be unique per machine
NODE_ID=node-1

# Comma-separated peer URLs (e.g. https://192.168.1.10:8443)
PEERS=

# Logging
LOG_LEVEL=INFO